PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://elite:elite_password@localhost:5432/elite
DEFAULT_TENANT_SLUG=elite
DEFAULT_TENANT_NAME=Elite
DEFAULT_CURRENCY=QAR

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:4200,http://localhost:4300,https://elitecollections.qa,https://www.elitecollections.qa,https://admin.elitecollections.qa

# Environment
NODE_ENV=development

# Media storage. In production, use one shared persistent location for every
# API instance, or replace the disk driver with a shared object-storage driver.
STORAGE_DRIVER=disk
UPLOADS_DIR=./uploads
UPLOADS_PUBLIC_BASE=/uploads

# Auth — server-side session for the admin portal (cookie + Postgres-backed
# store). Override SESSION_SECRET in production with a long random string.
SESSION_SECRET=dev-session-secret-change-me-in-production
SESSION_COOKIE_NAME=elite.sid
SESSION_MAX_AGE_MS=43200000   # 12h
SESSION_COOKIE_SECURE=false   # set true in production (https)
SESSION_COOKIE_SAMESITE=lax   # 'none' if admin runs on a different origin in prod

# NBOX webhook signing secret — copied from NBOX after creating the endpoint.
NBOX_WEBHOOK_SECRET=replace-with-nbox-webhook-secret

# NBOX API credentials — used to quote delivery during checkout and create
# shipments after payment is confirmed. Endpoint paths are configurable because
# NBOX may provide account-specific API paths in the merchant portal.
NBOX_API_BASE_URL=https://uat.portal.nbox.qa
NBOX_API_TOKEN=replace-with-nbox-api-token
NBOX_API_KEY=
NBOX_AUTH_HEADER=Authorization
NBOX_AUTH_SCHEME=Bearer
NBOX_RATE_ENDPOINT=replace-with-rate-endpoint-path
NBOX_SHIPMENT_ENDPOINT=replace-with-create-shipment-endpoint-path
NBOX_DEFAULT_SERVICE_CODE=
NBOX_DEFAULT_ITEM_WEIGHT_GRAMS=1000
NBOX_ORIGIN_NAME=Elite Collections
NBOX_ORIGIN_PHONE=
NBOX_ORIGIN_EMAIL=admin@elitecollections.qa
NBOX_ORIGIN_ADDRESS=
NBOX_ORIGIN_CITY=Doha
NBOX_ORIGIN_COUNTRY=QA

# Default admin user — created on first server boot if no users exist for the
# tenant. Change immediately in production.
DEFAULT_ADMIN_EMAIL=admin@elite.local
DEFAULT_ADMIN_PASSWORD=elite-admin
DEFAULT_ADMIN_NAME=Yusuf Hamad
