PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://elite:elite_password@localhost:5432/elite
DEFAULT_TENANT_SLUG=elite
DEFAULT_TENANT_NAME=Elite
DEFAULT_CURRENCY=QAR

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:4200,http://localhost:4300,https://elitecollections.qa,https://www.elitecollections.qa,https://admin.elitecollections.qa

# Environment
NODE_ENV=development

# Media storage. In production, use one shared persistent location for every
# API instance, or replace the disk driver with a shared object-storage driver.
STORAGE_DRIVER=disk
UPLOADS_DIR=./uploads
UPLOADS_PUBLIC_BASE=/uploads

# Email delivery for restock notifications and contact enquiries.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Elite Collections <hello@elitecollections.qa>"
CONTACT_EMAIL_TO=hello@elitecollections.qa

# Auth — server-side session for the admin portal (cookie + Postgres-backed
# store). Override SESSION_SECRET in production with a long random string.
SESSION_SECRET=dev-session-secret-change-me-in-production
SESSION_COOKIE_NAME=elite.sid
SESSION_MAX_AGE_MS=43200000   # 12h
SESSION_COOKIE_SECURE=false   # set true in production (https)
SESSION_COOKIE_SAMESITE=lax   # 'none' if admin runs on a different origin in prod

# NBOX webhook signing secret — copied from NBOX after creating the endpoint.
NBOX_WEBHOOK_SECRET=replace-with-nbox-webhook-secret

# NBOX API credentials — used to quote delivery during checkout and create
# shipments after payment is confirmed.
# Live: https://nbox.now/api
# Staging: https://staging.nbox.now/api
NBOX_API_BASE_URL=https://nbox.now/api
NBOX_API_TOKEN=replace-with-nbox-api-token
NBOX_SHOP_DOMAIN=elitecollections.qa
NBOX_API_KEY=
NBOX_AUTH_HEADER=x-nbox-shop-token
NBOX_AUTH_SCHEME=
# Outbound NBOX API paths from NBOX docs. Do not use /api/webhooks/nbox here.
NBOX_RATE_ENDPOINT=/rates
NBOX_SHIPMENT_ENDPOINT=/order
NBOX_DEFAULT_SERVICE_CODE=
NBOX_DEFAULT_ITEM_WEIGHT_GRAMS=1000
NBOX_DEFAULT_ITEM_LENGTH_CM=35
NBOX_DEFAULT_ITEM_WIDTH_CM=25
NBOX_DEFAULT_ITEM_HEIGHT_CM=15
NBOX_ORIGIN_NAME=Elite Collections
NBOX_ORIGIN_PHONE=
NBOX_ORIGIN_EMAIL=admin@elitecollections.qa
NBOX_ORIGIN_ADDRESS=replace-with-pickup-address
NBOX_ORIGIN_CITY=Doha
NBOX_ORIGIN_STATE=Doha
NBOX_ORIGIN_COUNTRY=QA
NBOX_ORIGIN_ZIP=0000

# ─── Sadad Payment Gateway (Web Checkout 2.1) ───────────────────────────────
# Credentials from the SADAD Merchant Panel → Payment Gateway → API / Secret Key
# The SAME endpoint is used for both test and live; environment is determined
# by the Secret Key used (Test Key = sandbox, Live Key = real transactions).
SADAD_MERCHANT_ID=replace-with-your-merchant-id
SADAD_SECRET_KEY=replace-with-your-secret-key
SADAD_ENDPOINT=https://sadadqa.com/webpurchase
SADAD_CORS_ORIGINS=https://sadadqa.com
# WEBSITE value shown in the SADAD merchant panel (e.g. your domain name)
SADAD_WEBSITE=elitecollections.qa
# Public origin that proxies /api to this server — used to build CALLBACK_URL
SERVER_URL=https://elitecollections.qa
# Full public URL of the storefront — used to redirect customers after payment
STOREFRONT_URL=https://elitecollections.qa

# Default admin user — created on first server boot if no users exist for the
# tenant. Change immediately in production.
DEFAULT_ADMIN_EMAIL=admin@elite.local
DEFAULT_ADMIN_PASSWORD=elite-admin
DEFAULT_ADMIN_NAME=Yusuf Hamad
